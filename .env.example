# App Configuration
APP_CLIENT_ID=your_client_id_here
APP_CLIENT_SECRET=your_client_secret_here
APP_ENCRYPTION_IV=your_16_char_iv_here
APP_ENCRYPTION_SECRET=your_encryption_secret_here
APP_MODE=development

# AWS Configuration
AWS_ACCESS_KEY=your_aws_access_key
AWS_API_VERSION=2006-03-01
AWS_BUCKET_NAME=your_bucket_name
AWS_ENDPOINT=https://your-bucket.s3.region.amazonaws.com
AWS_REGION=ap-south-1
AWS_SECRET_KEY=your_aws_secret_key

# CORS Configuration
# Comma-separated list of allowed origins (no spaces around commas recommended)
# Include all frontend URLs that need to access this API
# Example: CORS_ORIGIN=http://localhost:5173,http://localhost:3001,https://app.example.com
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3001,http://localhost:4000

# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database

# Email Configuration
EMAIL_VERIFICATION_REDIRECT_URL=http://localhost:3000

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key

# Frontend Configuration
FRONTEND_RESET_REDIRECT=http://localhost:3000

# Google Configuration
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# JWT Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_ACCESS_TOKEN_EXPIRE=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_TOKEN_EXPIRE=7d

# Mail Configuration
MAIL_HOST=smtp.example.com
MAIL_PASS=your_mail_password
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@example.com

# Node Environment
NODE_ENV=development
PORT=3000

# Razorpay Configuration (use test keys for development)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# SMS Configuration (Fast2SMS)
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Old SMS India Hub (deprecated - can be removed)
# SMS_API_KEY=your_sms_api_key
# SMS_API_URL=http://cloud.smsindiahub.in/api/mt/SendSMS
# SMS_DLT_TEMPLATE_ID=your_template_id
# SMS_PEID=your_peid
# SMS_SENDER_ID=SMSHUB

# Support Email
SUPPORT_EMAIL=support@example.com
SUPPORT_REPLY_EMAIL=reply@example.com

# Platform Configuration
PLATFORM_FEE_PERCENT=8
